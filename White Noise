{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyPiDrHpGIYkKqk2ip/mz88I"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"markdown","source":["# 1. Generate 10 Minutes of White Noise\n","This step generates 10 minutes of pure, unstructured white noise and saves it to a designated folder in Google Drive. This acts as our negative control."],"metadata":{"id":"mcvl7OLmYAt9"}},{"cell_type":"code","execution_count":4,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"jL-l6U3qX8g4","executionInfo":{"status":"ok","timestamp":1782317585188,"user_tz":240,"elapsed":204134,"user":{"displayName":"Eyosias Gebremeskel","userId":"04837293871017333340"}},"outputId":"0d8af960-0044-4c40-fab3-e12566371109"},"outputs":[{"output_type":"stream","name":"stdout","text":["Collecting colorednoise\n","  Downloading colorednoise-2.2.0-py3-none-any.whl.metadata (1.4 kB)\n","Requirement already satisfied: numpy>=1.17.0 in /usr/local/lib/python3.12/dist-packages (from colorednoise) (2.0.2)\n","Downloading colorednoise-2.2.0-py3-none-any.whl (4.6 kB)\n","Installing collected packages: colorednoise\n","Successfully installed colorednoise-2.2.0\n","Drive already mounted at /content/drive; to attempt to forcibly remount, call drive.mount(\"/content/drive\", force_remount=True).\n","Starting 10-Hour Audio Generation (Chunked to prevent RAM crashes)...\n","\n","1. Generating White Noise...\n","   Generating chunk 1/10...\n","   Generating chunk 2/10...\n","   Generating chunk 3/10...\n","   Generating chunk 4/10...\n","   Generating chunk 5/10...\n","   Generating chunk 6/10...\n","   Generating chunk 7/10...\n","   Generating chunk 8/10...\n","   Generating chunk 9/10...\n","   Generating chunk 10/10...\n","\n","2. Generating Pink Noise (1/f)...\n","   Generating chunk 1/10...\n","   Generating chunk 2/10...\n","   Generating chunk 3/10...\n","   Generating chunk 4/10...\n","   Generating chunk 5/10...\n","   Generating chunk 6/10...\n","   Generating chunk 7/10...\n","   Generating chunk 8/10...\n","   Generating chunk 9/10...\n","   Generating chunk 10/10...\n","\n","✅ Both 10-hour audio files successfully saved to: /content/drive/MyDrive/Noise_Control_Audio\n"]}],"source":["!pip install colorednoise\n","\n","import os\n","import numpy as np\n","import colorednoise as cn\n","from scipy.io.wavfile import write\n","from google.colab import drive\n","\n","# Mount Google Drive\n","drive.mount('/content/drive')\n","\n","AUDIO_FOLDER = \"/content/drive/MyDrive/Noise_Control_Audio\"\n","if not os.path.exists(AUDIO_FOLDER):\n","    os.makedirs(AUDIO_FOLDER)\n","\n","sample_rate = 44100\n","chunk_duration = 3600.0  # 1 hour per chunk\n","num_chunks = 10          # 10 chunks = 10 hours\n","samples_per_chunk = int(sample_rate * chunk_duration)\n","\n","print(\"Starting 10-Hour Audio Generation (Chunked to prevent RAM crashes)...\")\n","\n","# --- Generate 10 Hours of White Noise ---\n","print(\"\\n1. Generating White Noise...\")\n","white_noise_path = os.path.join(AUDIO_FOLDER, \"white_noise_10hr.wav\")\n","# Open file in binary append mode to stitch chunks together\n","with open(white_noise_path, 'wb') as f:\n","    for i in range(num_chunks):\n","        print(f\"   Generating chunk {i+1}/{num_chunks}...\")\n","        noise = np.random.uniform(-1.0, 1.0, samples_per_chunk)\n","        noise_scaled = np.int16(noise * 32767)\n","        write(f, sample_rate, noise_scaled)\n","\n","# --- Generate 10 Hours of Pink Noise ---\n","print(\"\\n2. Generating Pink Noise (1/f)...\")\n","pink_noise_path = os.path.join(AUDIO_FOLDER, \"pink_noise_10hr.wav\")\n","with open(pink_noise_path, 'wb') as f:\n","    for i in range(num_chunks):\n","        print(f\"   Generating chunk {i+1}/{num_chunks}...\")\n","        noise = cn.powerlaw_psd_gaussian(1, samples_per_chunk)\n","        # Normalize to prevent clipping\n","        noise = noise / np.max(np.abs(noise))\n","        noise_scaled = np.int16(noise * 32767)\n","        write(f, sample_rate, noise_scaled)\n","\n","print(f\"\\n✅ Both 10-hour audio files successfully saved to: {AUDIO_FOLDER}\")"]},{"cell_type":"markdown","source":["# 2. Process Audio Files and Generate Timbral Code-Words\n","This step loads the generated noise, segments it into 85.3 ms windows, isolates the frequencies using an STFT, groups them into 22 Bark bands, and performs binary quantization to generate 22-bit code words."],"metadata":{"id":"0UDloK41YCFe"}},{"cell_type":"code","source":["import librosa\n","import numpy as np\n","import os\n","import glob\n","\n","INPUT_FOLDER = \"/content/drive/MyDrive/Noise_Control_Audio\"\n","OUTPUT_FOLDER = \"/content/drive/MyDrive/Noise_Control_Codewords\"\n","WINDOW_LENGTH_MS = 85.3\n","bark_edges = [0, 100, 200, 300, 400, 510, 630, 770, 920, 1080, 1270,\n","              1480, 1720, 2000, 2320, 2700, 3150, 3700, 4400, 5300,\n","              6400, 7700, 9500]\n","\n","if not os.path.exists(OUTPUT_FOLDER):\n","    os.makedirs(OUTPUT_FOLDER)\n","\n","audio_files = glob.glob(os.path.join(INPUT_FOLDER, \"*.wav\"))\n","print(f\"Found {len(audio_files)} massive audio files. Starting analysis...\\n\")\n","\n","for audio_path in audio_files:\n","    base_name = os.path.splitext(os.path.basename(audio_path))[0]\n","    output_filename = os.path.join(OUTPUT_FOLDER, f\"{base_name}_codewords.txt\")\n","\n","    if os.path.exists(output_filename):\n","        print(f\"'{base_name}' already processed. Skipping...\")\n","        continue\n","\n","    print(f\"Analyzing {base_name} (This will take a while)...\")\n","\n","    # Load audio using librosa's stream to handle 3GB files without crashing RAM\n","    stream = librosa.stream(audio_path, block_length=256, frame_length=4096, hop_length=4096)\n","\n","    # We bypass librosa.load to save RAM, using direct STFT processing\n","    sr = 44100\n","    win_length = int(sr * (WINDOW_LENGTH_MS / 1000.0))\n","\n","    # Since streaming STFT manually is complex in librosa, we will load with a standard sample rate\n","    # but rely on Colab's swap space if needed.\n","    y, sr = librosa.load(audio_path, sr=None)\n","\n","    stft_matrix = librosa.stft(y, n_fft=win_length, hop_length=win_length, window='blackmanharris')\n","    power_spectrum = np.abs(stft_matrix)**2\n","    fft_freqs = librosa.fft_frequencies(sr=sr, n_fft=win_length)\n","\n","    num_windows = power_spectrum.shape[1]\n","    bark_spectrogram = np.zeros((22, num_windows))\n","\n","    for i in range(22):\n","        idx = np.where((fft_freqs >= bark_edges[i]) & (fft_freqs < bark_edges[i+1]))[0]\n","        bark_spectrogram[i, :] = np.sum(power_spectrum[idx, :], axis=0)\n","\n","    window_energy_sums = np.sum(bark_spectrogram, axis=0) + 1e-10\n","    norm_bark = bark_spectrogram / window_energy_sums\n","\n","    medians = np.median(norm_bark, axis=1, keepdims=True)\n","    quantized_bark = (norm_bark >= medians).astype(int)\n","\n","    with open(output_filename, 'w') as f:\n","        for j in range(num_windows):\n","            word = \"\".join(quantized_bark[:, j].astype(str))\n","            f.write(word + \"\\n\")\n","\n","    print(f\"  -> ✅ Exported {num_windows} code-words for {base_name}.\")\n","\n","print(\"\\n🎉 All 10-hour processing complete!\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"rBX35degYGky","executionInfo":{"status":"ok","timestamp":1782317608024,"user_tz":240,"elapsed":22831,"user":{"displayName":"Eyosias Gebremeskel","userId":"04837293871017333340"}},"outputId":"7d728910-04d3-48e6-d552-5795728d1912"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["Found 3 massive audio files. Starting analysis...\n","\n","Analyzing white_noise_control_10min (This will take a while)...\n","  -> ✅ Exported 7036 code-words for white_noise_control_10min.\n","Analyzing white_noise_10hr (This will take a while)...\n","  -> ✅ Exported 42213 code-words for white_noise_10hr.\n","Analyzing pink_noise_10hr (This will take a while)...\n","  -> ✅ Exported 42213 code-words for pink_noise_10hr.\n","\n","🎉 All 10-hour processing complete!\n"]}]},{"cell_type":"markdown","source":["# 3. Plot Rank-Frequency Distribution\n","This step aggregates the code-words, ranks them by frequency, and outputs the final Log-Log plot to verify the absence of a Zipfian distribution in the control data."],"metadata":{"id":"0Hony7iDYH04"}},{"cell_type":"code","source":["import os\n","import glob\n","import numpy as np\n","import matplotlib.pyplot as plt\n","from collections import Counter\n","\n","CODEWORDS_FOLDER = \"/content/drive/MyDrive/Noise_Control_Codewords\"\n","\n","def get_frequencies(file_path):\n","    counts = Counter()\n","    with open(file_path, 'r') as f:\n","        counts.update(f.read().splitlines())\n","    return sorted(list(counts.values()), reverse=True), sum(counts.values())\n","\n","# Find the files\n","white_file = glob.glob(os.path.join(CODEWORDS_FOLDER, \"*white*.txt\"))[0]\n","pink_file = glob.glob(os.path.join(CODEWORDS_FOLDER, \"*pink*.txt\"))[0]\n","\n","print(\"Calculating rank-frequency distributions...\")\n","freq_w, frames_w = get_frequencies(white_file)\n","freq_p, frames_p = get_frequencies(pink_file)\n","\n","rank_w = np.arange(1, len(freq_w) + 1)\n","rank_p = np.arange(1, len(freq_p) + 1)\n","\n","# Set up the dual graph\n","fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 7))\n","fig.suptitle('Zipfian Evaluation of Control Noise Data (10 Hours Each)', fontsize=18, y=1.05)\n","\n","# Plot 1: White Noise\n","ax1.loglog(rank_w, freq_w, marker='o', linestyle='none', color='#d62728', alpha=0.6, markersize=4)\n","ax1.set_title(f\"White Noise Control\\n(Total Frames: {frames_w:,})\", fontsize=14)\n","ax1.set_xlabel(\"Rank (Log Scale)\", fontsize=12)\n","ax1.set_ylabel(\"Frequency (Log Scale)\", fontsize=12)\n","ax1.grid(True, which=\"both\", ls=\"--\", alpha=0.5)\n","\n","# Plot 2: Pink Noise\n","ax2.loglog(rank_p, freq_p, marker='o', linestyle='none', color='#1f77b4', alpha=0.6, markersize=4)\n","ax2.set_title(f\"Pink Noise Control\\n(Total Frames: {frames_p:,})\", fontsize=14)\n","ax2.set_xlabel(\"Rank (Log Scale)\", fontsize=12)\n","ax2.grid(True, which=\"both\", ls=\"--\", alpha=0.5)\n","\n","plt.tight_layout()\n","\n","# Save the high-resolution graph\n","output_image = os.path.join(CODEWORDS_FOLDER, \"Control_Noise_Comparison_Graph.png\")\n","plt.savefig(output_image, dpi=300, bbox_inches='tight')\n","plt.show()\n","\n","print(f\"✅ Graphing complete. High-res image saved to: {output_image}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":90},"id":"-9O1AWETYJl6","executionInfo":{"status":"ok","timestamp":1782317610932,"user_tz":240,"elapsed":2904,"user":{"displayName":"Eyosias Gebremeskel","userId":"04837293871017333340"}},"outputId":"cdda8e37-4236-4726-979b-0e3fdc080b0d"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["Calculating rank-frequency distributions...\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1600x700 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["✅ Graphing complete. High-res image saved to: /content/drive/MyDrive/Noise_Control_Codewords/Control_Noise_Comparison_Graph.png\n"]}]}]}